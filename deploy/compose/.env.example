COMPOSE_PROJECT_NAME=praxiara

# Database identities and mandatory secret placeholders
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=replace-with-postgres-superuser-password
POSTGRES_DEFAULT_DATABASE=postgres
PRAXIARA_DB_NAME=praxiara
PRAXIARA_DB_USER=praxiara
PRAXIARA_DB_PASSWORD=replace-with-praxiara-database-password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=replace-with-keycloak-database-password
TEMPORAL_DB_NAME=temporal
TEMPORAL_VISIBILITY_DB_NAME=temporal_visibility
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=replace-with-temporal-database-password

# Cache and object storage mandatory secret placeholders
VALKEY_PASSWORD=replace-with-valkey-password-32-chars
SEAWEEDFS_S3_ACCESS_KEY=replace-with-s3-access-key
SEAWEEDFS_S3_SECRET_KEY=replace-with-s3-secret-key-at-least-32-chars
SEAWEEDFS_S3_ALLOWED_ORIGINS=http://localhost:5173
SEAWEEDFS_VOLUME_MAX=16
SEAWEEDFS_VOLUME_SIZE_LIMIT_MB=1024

# Identity mandatory secret placeholder
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=replace-with-keycloak-admin-password
KEYCLOAK_HOSTNAME=http://localhost:8081/auth
KEYCLOAK_ADMIN_URL=http://host.docker.internal:8081/auth
PRAXIARA_SEED_ADMIN_USERNAME=admin
PRAXIARA_SEED_ADMIN_PASSWORD_FILE=/Users/jklebucki/Projects/secrets/praxiara-seed-admin-password.txt

# Workflow
TEMPORAL_DEFAULT_NAMESPACE=praxiara
TEMPORAL_DEFAULT_NAMESPACE_RETENTION=168h
TEMPORAL_CORS_ORIGINS=http://localhost:5173
TEMPORAL_LOG_LEVEL=info

# Local LLM runtime
OLLAMA_KEEP_ALIVE=10m
OLLAMA_NUM_PARALLEL=1

# Retention and capacity
PROMETHEUS_RETENTION=7d
MAILPIT_MAX_MESSAGES=5000

# Edge upstreams
PRAXIARA_API_UPSTREAM=host.docker.internal:5080
PRAXIARA_WEB_UPSTREAM=host.docker.internal:5173
KEYCLOAK_UPSTREAM=keycloak:8080

# Loopback-only development ports
POSTGRES_PORT=5432
VALKEY_PORT=6379
SEAWEEDFS_S3_PORT=8333
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_MASTER_PORT=9333
KEYCLOAK_PORT=8081
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8082
OLLAMA_PORT=11434
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
JAEGER_UI_PORT=16686
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
EDGE_HTTP_PORT=8080
EDGE_HTTPS_PORT=8443
