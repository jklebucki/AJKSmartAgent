{
	admin off
	auto_https disable_redirects
}

(common_routes) {
	encode zstd gzip

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		X-Frame-Options SAMEORIGIN
	}

	@health path /healthz
	handle @health {
		respond "ok" 200
	}

	handle /auth/* {
		reverse_proxy {$KEYCLOAK_UPSTREAM}
	}

	handle /api/* {
		reverse_proxy {$PRAXIARA_API_UPSTREAM}
	}

	handle {
		reverse_proxy {$PRAXIARA_WEB_UPSTREAM}
	}
}

:80 {
	import common_routes
}

https://localhost {
	tls internal
	import common_routes
}
